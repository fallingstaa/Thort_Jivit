rules_version = '2';

// Firebase Storage Rules for Life Record App
// These rules allow authenticated users to upload and read their own videos
service firebase.storage {
  match /b/{bucket}/o {
    // User videos: allow read/write for authenticated users to their own data
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Alternative: more permissive for testing (allow all authenticated users)
    // Remove this and use the above rule for production
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
